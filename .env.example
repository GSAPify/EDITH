# EDITH environment — copy to .env and fill in. NEVER commit .env.
# All real secrets live in the macOS Keychain (via `keyring`) at runtime, not here.
# These are placeholders only.

# --- Bifrost (Pattern's model gateway) — needed by Brain/Router (later slices) ---
BIFROST_BASE_URL=https://bifrost.example.internal/v1
BIFROST_API_KEY=replace-me-not-a-real-key

# --- Memory store ---
# Directory that holds the Kuzu DB. In production this lives on a dedicated
# encrypted APFS volume (key in Keychain). For dev, a local path with 0700 perms.
EDITH_DATA_DIR=~/.edith/data
